{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["bun-types"],
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"paths": {
			"~src/*": ["./src/*"]
		}
	},
	"include": ["src/**/*.ts", "main.ts"],
	"exclude": ["state/**"]
}
