{
  client: {
    backgroundLoadTabs: true,
    backgroundLoadBlobs: true,
    repaintAfterBlobLoad: true,
    pausedNoticeDelayMs: 50
  },
  blocks: { blobBatchSize: 64 },
  render: { forkHistoryDimFactor: 0.82 },
  agentLoop: { maxIterations: 50 },
  memory: { warnBytes: 1500000000, killBytes: 5000000000 },
  models: { default: 'gpt' },
  subscriptionUsage: { censorEmails: true }
  clipboard: {
    multilinePasteFileLineLimit: 5
  }
}
