#!/bin/bash

export HAL_DIR="${HAL_DIR:-$(cd "$(dirname "$0")" && pwd)}"
export LAUNCH_CWD="${LAUNCH_CWD:-$(pwd)}"
export HAL_STATE_DIR="${HAL_STATE_DIR:-$HAL_DIR/state}"
cd "$HAL_DIR" || exit 1

# If -f/--fresh, create a 4-char alphanumeric temp state dir once
# and reuse it across restarts. Strip -f so args.ts doesn't re-create.
pass_args=()
for arg in "$@"; do
	if [[ "$arg" == "-f" || "$arg" == "--fresh" ]]; then
		[[ -z "$_hal_fresh_dir" ]] && _hal_fresh_dir=$(bun src/fresh-dir.ts)
		export HAL_STATE_DIR="$_hal_fresh_dir"
	elif [[ "$arg" == "-s" || "$arg" == "--self" ]]; then
		export LAUNCH_CWD="$HAL_DIR"
	else
		pass_args+=("$arg")
	fi
done

while true; do
	perl -MTime::HiRes=time -e 'printf "%d\n", time()*1000' > "/tmp/hal-startup-$$.txt"
	bun main.ts "${pass_args[@]}"
	code=$?
	[ "$code" -ne 100 ] && exit "$code"
done
