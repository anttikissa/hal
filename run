#!/bin/bash

export HAL_DIR="${HAL_DIR:-$(cd "$(dirname "$0")" && pwd)}"
export LAUNCH_CWD="${LAUNCH_CWD:-$(pwd)}"
export HAL_STATE_DIR="${HAL_STATE_DIR:-$HAL_DIR/state}"
cd "$HAL_DIR" || exit 1

# If -f/--fresh, create a temp state dir once and reuse across restarts.
for arg in "$@"; do
	if [[ "$arg" == "-f" || "$arg" == "--fresh" ]]; then
		base="/tmp/hal/state"
		mkdir -p "$base"
		export HAL_STATE_DIR=$(mktemp -d "$base/XXXXXX")
		break
	fi
done

while true; do
	perl -MTime::HiRes=time -e 'printf "%d\n", time()*1000' > "/tmp/hal-startup-$$.txt"
	bun main.ts "$@"
	code=$?
	[ "$code" -ne 100 ] && exit "$code"
done
