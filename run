#!/usr/bin/env bash
set -uo pipefail

# Resolve symlinks to find the real .hal directory.
hal_dir="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

args=()
for arg in "$@"; do
	case "$arg" in
		-f)
			# Fresh state means this invocation is intentionally isolated: no other
			# terminal can join it, and it cannot join the normal host.
			export HAL_STATE_DIR="$(mktemp -d /tmp/hal-state-XXXXXX)"
			;;
		*)
			args+=("$arg")
			;;
	esac
done

while true; do
	startup_epoch_ms="$(NO_COLOR=1 bun -e 'console.log(Date.now())')"
	if [ "${#args[@]}" -eq 0 ]; then
		# macOS still ships Bash 3.2. Under `set -u`, expanding an empty array raises
		# "unbound variable", so only forward the array when it actually has items.
		HAL_LOG=1 HAL_STARTUP_TIMESTAMP="$startup_epoch_ms" bun "$hal_dir/src/main.ts"
	else
		HAL_LOG=1 HAL_STARTUP_TIMESTAMP="$startup_epoch_ms" bun "$hal_dir/src/main.ts" "${args[@]}"
	fi

	code=$?
	# Exit code 100 restarts - used by Ctrl-R.
	[ "$code" -ne 100 ] && exit "$code"
done
