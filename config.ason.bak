{
  // provider/model-id — or alias: claude, codex, mock
  defaultModel: 'anthropic/claude-opus-4-6',
  theme: 'hal',
  // Warn when context window usage exceeds this ratio (0-1)
  contextWarnThreshold: 0.8,

  // Max concurrent agent sessions (extra messages queue)
  maxConcurrentSessions: 8,
  // Max visible lines in the prompt input area
  maxPromptLines: 15,
  // How many recent tool results to send in full (older ones get a placeholder)
  recentToolResults: 3,

  // Cursor blink periods (ms):
  //
  // When Hal is typing (or thinking), the cursor blinks faster to indicate activity.
  cursorBlinkBusy: 500,
  // When Hal stops and waits for user input, it gradually slows down; first to idle state...
  cursorBlinkIdle: 1000,
  // And after `cursorDormantDelay` ms, very slowly as if it has fallen asleep.
  // (In this state, cursor also changes to underscore)
  cursorBlinkDormant: 2000,
  // Takes this many ms to become dormant
  cursorDormantDelay: 10000,

  // The user is a slower thinker, and their cursor therefore a slower blinker.
  cursorBlinkUser: 750,

  // debug flags

  /*debug: {
    // Stream state files, keypresses, snapshots to debug log (needed for /bug)
    recordEverything: true,
    tokens: {
      // Log system prompt + messages token count on first response
      sys: true,
      // Log token counts on every response
      spam: false,
      // Log context window percentage after each response
      context: false
    }
  }*/
  debug: 'all'
  eval: true,
}
